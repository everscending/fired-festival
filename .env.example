# ---------------------------------------------------------------------------
# Alter Ego — environment variables
# Copy this file to ".env" and fill in real values:  cp .env.example .env
# ---------------------------------------------------------------------------

# === app.py (DEFAULT entry point, per README) ===
# OpenAI API key (uses gpt-4o-mini via the openai-agents SDK)
OPENAI_API_KEY=

# Mailtrap — used to email captured user details / unknown questions
MAILTRAP_API_KEY=

# Verified sender for escalation/alarm notifications
EMAIL_FROM=

# Recipient for escalation/alarm emails (defaults to EMAIL_FROM if unset)
EMAIL_TO=

# === Harness knobs (optional) ===
# Selects the worker implementation: linkedin (default) | echo | rogue
ACTIVE_WORKER=linkedin

# Model used by the demo worker
MODEL=gpt-4o-mini

# Optional OTel sink (OTLP/HTTP). If unset, spans print to the console (logs).
OTEL_EXPORTER_OTLP_ENDPOINT=

# Where the SQLite run journal lives (ephemeral on HF Spaces)
HARNESS_STORE_PATH=harness_runs.sqlite3
